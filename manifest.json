{
    "manifest_version": 3,
    "name": "PYEX PAYLOAD EXTENSION",
    "version": "2.0.0",
    "description": "Security Testing Payload Manager - Store, search, and copy payloads for penetration testing",
    "author": "Peon Team",
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "assets/icons/icon16.png",
            "48": "assets/icons/icon48.png",
            "128": "assets/icons/icon128.png"
        }
    },
    "icons": {
        "16": "assets/icons/icon16.png",
        "48": "assets/icons/icon48.png",
        "128": "assets/icons/icon128.png"
    },
    "permissions": [
        "storage",
        "clipboardWrite",
        "alarms",
        "tabs",
        "activeTab",
        "scripting",
        "unlimitedStorage",
        "webRequest"
    ],
    "host_permissions": [
        "https://raw.githubusercontent.com/*",
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background/updater.js",
        "scripts": ["background/updater.js"]
    },
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Shift+L",
                "mac": "Command+Shift+L"
            },
            "description": "Buka PYEX"
        }
    },
    "web_accessible_resources": [
        {
            "resources": [
                "payloads/*.json",
                "utils/*.json",
                "content/*.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    

"browser_specific_settings": {
  "gecko": {
    "id": "pyex@dan3-wtf.com",
    "data_collection_permissions": {
      "required": ["none"]
    }
  }
}
}
